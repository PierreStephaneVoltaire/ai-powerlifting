# IF Prototype A1 - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# Required: OpenRouter API Key
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DynamoDB Table Names
IF_CORE_TABLE_NAME=if-core
IF_HEALTH_TABLE_NAME=if-health
IF_SESSIONS_TABLE_NAME=if-sessions
ANALYSIS_CACHE_TABLE_NAME=if-powerlifting-analysis-cache
IF_FINANCE_TABLE_NAME=if-finance
IF_DIARY_ENTRIES_TABLE_NAME=if-diary-entries
IF_DIARY_SIGNALS_TABLE_NAME=if-diary-signals
IF_PROPOSALS_TABLE_NAME=if-proposals

# =============================================================================
# Model Configuration (Provider-Agnostic via Presets)
# =============================================================================
# All models use OpenRouter presets by default for maximum flexibility.
# Override with specific models if needed.

# API model identifier (what clients send in the model field)
# Default: if-prototype
API_MODEL_NAME=if-prototype

# Tokenizer model for tiktoken (not LLM calls, just token counting)
# Default: gpt-4
TOKENIZER_MODEL=gpt-4

# Embedding model for LanceDB vector storage
# Default: all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Model for OpenWebUI suggestion/title generation
# Default: mistralai/mistral-nemo
SUGGESTION_MODEL=mistralai/mistral-nemo

# Comma-separated list of models for parallel conversation scoring
# Must support structured output / JSON mode
# Default: provider-agnostic mix
SCORING_MODELS=google/gemini-2.5-flash-lite,qwen/qwen3-32b,z-ai/glm-4.7-flash

# Model for topic shift detection
# Should be a fast, cheap model
# Default: z-ai/glm-4.7-flash
TOPIC_SHIFT_MODEL=z-ai/glm-4.7-flash

# Model for directive content rewriting
# Default: openrouter/@preset/heavy
DIRECTIVE_REWRITE_MODEL=openrouter/@preset/heavy

# Model for conversation condensation
# Default: openrouter/@preset/general
CONDENSER_MODEL=openrouter/@preset/general

# Fallback model for heartbeat pondering
# Default: openrouter/@preset/general
HEARTBEAT_FALLBACK_MODEL=openrouter/@preset/general

# Fallback model for presets without defined models
# Default: openrouter/@preset/general
PRESET_FALLBACK_MODEL=openrouter/@preset/general

# Model for reflection engine and opinion formation
# Default: openrouter/@preset/general
REFLECTION_MODEL=openrouter/@preset/general

# Model for plan execution subagents
# Default: openrouter/@preset/standard
ORCHESTRATOR_SUBAGENT_MODEL=openrouter/@preset/standard

# Model for parallel analysis subagents
# Default: openrouter/@preset/air
ORCHESTRATOR_ANALYSIS_MODEL=openrouter/@preset/air

# Model for synthesis of parallel analysis results
# Default: openrouter/@preset/standard
ORCHESTRATOR_SYNTHESIS_MODEL=openrouter/@preset/standard

# Model for research agent spawned by health tools
# Default: openrouter/@preset/heavy
RESEARCH_AGENT_MODEL=openrouter/@preset/research

# =============================================================================
# Routing Configuration
# =============================================================================

# Number of recent messages to send to routing models and presets
# Default: 8
MESSAGE_WINDOW=8

# Crisis score threshold for mental health routing override
# Low default (0.3) because false negatives are catastrophic
# Default: 0.3
CRISIS_THRESHOLD=0.3

# Minimum top score for confident routing decision
# Default: 0.6
CONFIDENCE_THRESHOLD=0.6

# Minimum gap between top and second score for confident decision
# Default: 0.2
CONFIDENCE_GAP=0.2

# =============================================================================
# Tier System Configuration
# =============================================================================

# Tier upgrade threshold (fraction of context limit before upgrade)
# Default: 0.65
TIER_UPGRADE_THRESHOLD=0.65

# Context limits per tier (in tokens)
TIER_AIR_LIMIT=30000
TIER_STANDARD_LIMIT=120000
TIER_HEAVY_LIMIT=200000

# OpenRouter presets per tier
TIER_AIR_PRESET=@preset/air
TIER_STANDARD_PRESET=@preset/standard
TIER_HEAVY_PRESET=@preset/heavy

# =============================================================================
# Subagent Configuration
# =============================================================================

# Default preset for specialist subagents
# Default: @preset/standard
SPECIALIST_PRESET=@preset/standard

# Maximum turns per specialist subagent
# Default: 15
SPECIALIST_MAX_TURNS=15

# Deep thinker (pondering) preset
# Default: @preset/general
THINKING_PRESET=@preset/general

# Maximum turns for thinking subagent
# Default: 20
THINKING_MAX_TURNS=20

# Maximum turns per orchestrator subagent
# Default: 15
ORCHESTRATOR_MAX_TURNS=15

# Maximum turns for analysis subagents
# Default: 10
ORCHESTRATOR_ANALYSIS_MAX_TURNS=10

# =============================================================================
# Paths & Storage
# =============================================================================

# Local directory for file artifact generation
# Default: ./sandbox
SANDBOX_PATH=./sandbox

# Path to persistent memory store file
# Default: ./data/memory.json
MEMORY_DB_PATH=./data/memory.json

# Path for conversation persistence
# Default: ./data/conversations
PERSISTENCE_DIR=./data/conversations

# LanceDB base path for user facts
# Default: ./data/facts
FACTS_BASE_PATH=./data/facts

# Storage backend for webhook records
# Options: sqlite (default), dynamodb (future)
# Default: sqlite
STORE_BACKEND=sqlite

# SQLite database file path for webhook storage
# Default: ./data/store.db
STORAGE_DB_PATH=./data/store.db

# Context condensation threshold (in tokens)
# Default: 250000
CONTEXT_CONDENSE_THRESHOLD=250000

# =============================================================================
# Server Configuration
# =============================================================================

# API server bind address
# Default: 0.0.0.0
HOST=0.0.0.0

# API server bind port
# Default: 8000
PORT=8000

# Channel inactivity window (seconds) before batched messages are dispatched
# Default: 30
CHANNEL_DEBOUNCE_SECONDS=30

# Maximum characters per chunk for channel responses
# Discord has a 2000 char limit, 1500 provides safety margin
# Default: 1500
CHANNEL_MAX_CHUNK_CHARS=1500

# Polling interval (seconds) for OpenWebUI channel listener
# Default: 5.0
OPENWEBUI_POLL_INTERVAL=5.0

# =============================================================================
# Heartbeat Configuration
# =============================================================================

# Enable/disable heartbeat system for proactive engagement
# Default: true
HEARTBEAT_ENABLED=true

# Hours of inactivity before a channel is considered idle
# Default: 6.0
HEARTBEAT_IDLE_HOURS=6.0

# Hours to wait between heartbeat messages to the same channel
# Default: 6.0
HEARTBEAT_COOLDOWN_HOURS=6.0

# Time range when heartbeats should not be sent (UTC)
# Format: "HH:MM-HH:MM", spans midnight if start > end
# Set to empty string to disable quiet hours
# Default: 23:00-07:00
HEARTBEAT_QUIET_HOURS=23:00-07:00

# =============================================================================
# Reflection Configuration
# =============================================================================

# Enable/disable reflection system
# Default: true
REFLECTION_ENABLED=true

# Hours between periodic reflection
# Default: 6.0
REFLECTION_PERIODIC_HOURS=6.0

# Minimum turns before post-session reflection
# Default: 5
REFLECTION_POST_SESSION_MIN_TURNS=5

# Thresholds for triggering reflection
REFLECTION_THRESHOLD_UNCATEGORIZED=20
REFLECTION_THRESHOLD_GAPS_NO_CRITERIA=5
REFLECTION_THRESHOLD_OPINIONS_NO_RESPONSE=10

# Capability gap promotion threshold
# Default: 3
CAPABILITY_GAP_PROMOTION_THRESHOLD=3

# =============================================================================
# Terminal (Docker) Configuration
# =============================================================================

# Docker image for Open Terminal containers
# Default: ghcr.io/open-webui/open-terminal:latest
TERMINAL_IMAGE=ghcr.io/open-webui/open-terminal:latest

# Docker network for terminal containers
# Default: if-terminal-net
TERMINAL_NETWORK=if-terminal-net

# Memory limit per terminal container
# Default: 512m
TERMINAL_MEM_LIMIT=512m

# CPU quota (100000 = 1 CPU, 50000 = 0.5 CPU)
# Default: 50000
TERMINAL_CPU_QUOTA=50000

# Seconds before idle containers are stopped
# Default: 3600 (1 hour)
TERMINAL_IDLE_TIMEOUT=3600

# Seconds to wait for container health check
# Default: 30.0
TERMINAL_STARTUP_TIMEOUT=30.0

# Maximum number of concurrent terminal containers
# Default: 20
TERMINAL_MAX_CONTAINERS=20

# Docker named volumes host root path (for file serving)
# Set to empty string to disable direct host access
# Default: /var/lib/docker/volumes
TERMINAL_VOLUME_HOST_ROOT=/var/lib/docker/volumes

# =============================================================================
# Health Module Configuration
# =============================================================================

# Partition key value for health program storage
# Default: operator
HEALTH_PROGRAM_PK=operator

# Directory containing health PDF documents for RAG
# Default: docs/health
HEALTH_DOCS_DIR=docs/health

# =============================================================================
# Infrastructure Tables Configuration
# =============================================================================

# Default user PK for all infrastructure tables
# Default: operator
IF_USER_PK=operator

# =============================================================================
# Diary Configuration
# =============================================================================

# TTL for diary entries in days
# Default: 3
DIARY_TTL_DAYS=3

# Interval for automatic signal computation (hours)
# Default: 6.0
DIARY_SIGNAL_COMPUTE_INTERVAL_HOURS=6.0

# Model for diary signal computation
# Default: openrouter/@preset/air
DIARY_SIGNAL_MODEL=openrouter/@preset/air

# =============================================================================
# AWS Configuration (Optional)
# =============================================================================

# AWS region for DynamoDB
# Default: us-east-1
AWS_REGION=ca-central-1

# =============================================================================
# MCP Server API Keys (Optional)
# =============================================================================

# Google Sheets credentials (base64 encoded JSON)
GOOGLE_SHEETS_CREDENTIALS=

# Alpha Vantage API key for stock data
# Get free key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# Default: INFO
LOG_LEVEL=INFO

# Log file path
# Default: ./logs/app.log
LOG_FILE=./logs/app.log
