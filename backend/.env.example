# AWS Configuration
AWS_REGION=ca-central-1

# DynamoDB Table
DYNAMO_TABLE=if-health
IF_USER_TABLE=if-user
IF_SESSIONS_TABLE_NAME=if-sessions
ANALYSIS_CACHE_TABLE_NAME=if-powerlifting-analysis-cache

# Phase 2 Lambda configuration
# Region for the Phase 2 powerlifting tool Lambdas. Falls back to AWS_REGION when unset.
# POWERLIFTING_LAMBDA_REGION=ca-central-1
# Prefix for the deployed Lambda function names (tool name appended, e.g. pl-health_get_session).
# POWERLIFTING_LAMBDA_PREFIX=pl-

# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# Discord OAuth2 (FEAT-4.1: legacy path; the app continues to work without these)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback

# Authentik OIDC (FEAT-4.1: new path; supports social logins via Authentik)
# Set all four to enable the Authentik button. The button is shown when
# isAuthentikEnabled() returns true; it is hidden otherwise.
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_ISSUER_URL=  # e.g. https://auth.example.com/application/o/powerlifting
AUTHENTIK_REDIRECT_URI=http://localhost:3001/api/auth/authentik/callback

# Cookie configuration
COOKIE_DOMAIN=
COOKIE_SECURE=false
